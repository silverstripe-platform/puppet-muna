#!/usr/bin/php
<?php
/**
 * Retrieves Coralogix credentials through muna and writes them to a JSON
 * secrets file for consumption by the Vector activation script.
 *
 * Output: /etc/vector/secrets/coralogix.json
 *
 * Safe to run repeatedly. Exits gracefully if muna is not configured.
 */

include __DIR__.'/_muna_functions.php';

$aws_region = getenv('AWS_REGION');

if (!is_region($aws_region)) {
    quit("Region not valid or not set, skipping Coralogix setup");
}

$secretsDir = '/etc/vector/secrets';
$secretsFile = $secretsDir.'/coralogix.json';
$paramPath = 'coralogix/config';

if (!file_exists(NAMESPACE_CONFIG_PATH)) {
    quit(sprintf("Muna config file '%s' is missing, skipping Coralogix setup", NAMESPACE_CONFIG_PATH));
}

$namespaces = parse_ini_file(NAMESPACE_CONFIG_PATH, true);
if (!is_array($namespaces) || !isset($namespaces['stack']['path'])) {
    quit("Stack namespace not found, skipping Coralogix setup");
}

$stackPath = $namespaces['stack']['path'];
$munaPath = sprintf('%s/%s', $stackPath, $paramPath);

$munaCmd = sprintf(
    '/opt/muna/bin/muna export %s --region %s',
    escapeshellarg($munaPath),
    escapeshellarg($aws_region)
);

exec($munaCmd, $munaOutput, $exitCode);

if ($exitCode !== 0 || empty($munaOutput[0]) || $munaOutput[0] === '{}') {
    quit("Coralogix config not in Parameter Store, skipping");
}

$response = json_decode($munaOutput[0], true);
if (!is_array($response) || empty($response['config'])) {
    quit("Coralogix config not in Parameter Store, skipping");
}

$config = json_decode($response['config'], true);
if (!is_array($config)) {
    quit("Coralogix config incomplete, skipping");
}

$sendKey = $config['private_key'] ?? '';
$domain = $config['domain'] ?? '';

if (empty($sendKey) || empty($domain)) {
    quit("Coralogix config incomplete, skipping");
}

// Ensure secrets directory exists
if (!is_dir($secretsDir)) {
    mkdir($secretsDir, 0750, true);
}

$secrets = json_encode([
    'domain'   => $domain,
    'send_key' => $sendKey,
], JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES).PHP_EOL;

file_put_contents($secretsFile, $secrets);
chmod($secretsFile, 0640);

output("Coralogix credentials written to $secretsFile");
