<?php
# Managed by Puppet
define('WEBROOT_PATH', '<%= @webroot_path %>');
define('SSL_PATH', '<%= @ssl_path %>');
define('NAMESPACE_CONFIG_PATH', '/opt/muna/conf/namespaces.ini');
define('SSL_CONFIG_PATH', '/opt/muna/conf/ssl_%s.ini');

/**
* Detect AWS region from instance metadata (IMDSv2).
* Returns the region string or empty string on failure.
*/
function get_region() {
    $tokenUrl = 'http://169.254.169.254/latest/api/token';
    $regionUrl = 'http://169.254.169.254/latest/meta-data/placement/region';

    $tokenCtx = stream_context_create([
        'http' => [
            'method' => 'PUT',
            'header' => 'X-aws-ec2-metadata-token-ttl-seconds: 21600',
            'timeout' => 2,
        ],
    ]);
    $token = @file_get_contents($tokenUrl, false, $tokenCtx);

    if ($token === false) {
        return '';
    }

    $regionCtx = stream_context_create([
        'http' => [
            'method' => 'GET',
            'header' => sprintf('X-aws-ec2-metadata-token: %s', $token),
            'timeout' => 2,
        ],
    ]);

    $region = @file_get_contents($regionUrl, false, $regionCtx);
    if ($region === false) {
        return '';
    }

    return trim($region);
}

function output($message) {
    echo $message.PHP_EOL;
}

function quit($message, $code = 0) {
    output($message);
    exit($code);
}

function is_region($region) {
    $valid_regions = [
        'ap-southeast-2',
        'ap-southeast-6',
        'eu-west-1',
        'us-west-2',
    ];

    if (in_array($region, $valid_regions)) {
        return true;
    }

    return false;
}

<% if @http_proxy %>
putenv('http_proxy=<%= @http_proxy %>');
putenv('HTTP_PROXY=<%= @http_proxy %>');
<% end %>
<% if @https_proxy %>
putenv('https_proxy=<%= @https_proxy %>');
putenv('HTTPS_PROXY=<%= @https_proxy %>');
<% end %>
<% if @aws_key %>putenv('AWS_ACCESS_KEY_ID=<%= @aws_key %>');<% end %>
<% if @aws_secret %>putenv('AWS_SECRET_ACCESS_KEY=<%= @aws_secret %>');<% end %>
<% if @aws_region %>
putenv('AWS_REGION=<%= @aws_region %>');
<% else %>
if (!empty($argv[2])) {
    // Muna will not automatically pick this up from the PHP process
    putenv('AWS_REGION='.$argv[2]);
} else {
    putenv('AWS_REGION='.get_region());
}
<% end %>

